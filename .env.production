# Phyntom X8 Console — production defaults
#
# IMPORTANT: while the FastAPI backend (tools/ai_native/main.py) is NOT yet
# deployed alongside the static site on AWS, this stays `true` so the
# Console UI runs entirely off the fixtures in console/src/lib/mocks.ts.
#
# When you have the backend deployed and routed (e.g. nginx /v1/* → upstream
# FastAPI), set this to `false` and re-build.
VITE_USE_MOCK=true
